# ============================================================
# Shared Journey — environment variables
# Copy this file to .env.local and fill in values from your NEW
# Supabase project (Dashboard → Project Settings → API).
# .env.local is gitignored and must never be committed.
# ============================================================

# --- Public (browser-exposed) ---------------------------------------------
# Required for Supabase Auth + RLS, which now run in the client. These are
# SAFE to expose: the anon key only grants access that RLS explicitly allows.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# --- Server-only (secret) --------------------------------------------------
# Bypasses Row Level Security. Used for privileged server tasks and the
# one-time data migration script. NEVER prefix with NEXT_PUBLIC. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Data migration script only (scripts/migrate-to-space.js) -------------
# Credentials of the OLD single-tenant project to copy your data FROM, plus
# the new space_id to inject. Only needed while running the migration.
OLD_SUPABASE_URL=https://OLD-PROJECT-REF.supabase.co
OLD_SUPABASE_SERVICE_ROLE_KEY=old-service-role-secret-key
MIGRATION_TARGET_SPACE_ID=your-new-space-uuid
